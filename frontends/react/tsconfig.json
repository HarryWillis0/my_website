{
	"compilerOptions": {
		"esModuleInterop": true,
		"jsx": "react",
		"module": "esnext",
		"moduleResolution": "bundler",
		"lib": ["dom", "esnext"],
		"strict": true,
		"sourceMap": true,
		"target": "esnext",
		"paths": {
			"src/*": ["./src/*"]
		}
	},
	"exclude": ["node_modules"],
	"include": ["src"]
}
